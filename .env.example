# Copy to .env.local and fill in once you have real values. All optional —
# the site works without them, these just enable extra SEO/analytics wiring.

# Google Search Console: Settings > Ownership verification > HTML tag,
# copy just the "content" value (not the whole <meta> tag).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=6JQ3E9oH9VXQksOAhpdfHKzYfdyMG27Vt8nkg5Tn-Tw

# Bing Webmaster Tools: Settings > Ownership verification > HTML Meta Tag,
# copy just the "content" value.
NEXT_PUBLIC_BING_SITE_VERIFICATION=4F2510BF6B2669AE60A73BF97DC11B5D

# Google Analytics 4 measurement ID (starts with "G-"). Leave empty to
# skip loading GA entirely — no script is injected unless this is set.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-YPPMMBWQ72

# Contact form SMTP relay (Spacemail/Titan mailbox). Required for the
# contact form on /#contact to send mail. Get these from your mailbox's
# "mail client setup" page. Port 465 = implicit TLS, 587 = STARTTLS.
SMTP_HOST=mail.spacemail.com
SMTP_PORT=465
SMTP_USER=hello@janidudev.com
SMTP_PASS=JaniduHasmali22&Q
# Optional: defaults to SMTP_USER if omitted.
CONTACT_TO_EMAIL=hello@janidudev.com
